---
import { SwiperSlide} from "astro-swiper";
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { withBase } from '@/utils/withBase';

import Layout from '../layouts/Layout.astro';
import SwiperComponent from '../components/SwiperComponent.astro';
import CatOnVacuum from '../components/CatOnVacuum.astro';
import Popup from '../components/Popup.astro';

import { brands, brandLogo } from '../data/brandsData';

// images
import SHFEATURES1 from '../assets/img/sh-features.webp';
import SHFEATURES2 from '../assets/img/sh-features-2.webp';
import SHFEATURES3 from '../assets/img/sh-features-3.webp';
import SHFEATURES4 from '../assets/img/sh-features-4.webp';

import STEP1 from '../assets/img/step-1.webp';
import STEP2 from '../assets/img/step-2.webp';
import STEP3 from '../assets/img/step-3.webp';
import STEP4 from '../assets/img/step-4.webp';

const DEMO_HA_URL = 'https://demo.yourspace.multi-agent.io';

// Фото подхватываются автоматически, как только файлы появятся в src/assets/img/showcase/
// (нужные имена: demo-ha-cover, control-h2, control-relay, control-panel, control-tablet; webp/jpg/png)
const showcaseImages = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/img/showcase/*.{webp,jpg,jpeg,png}',
  { eager: true },
);
const showcase = (name: string): ImageMetadata | undefined =>
  Object.entries(showcaseImages).find(([path]) => path.includes(`/${name}.`))?.[1].default;

const demoCover = showcase('demo-ha-cover');

// pos — object-position для кропа фото в карточке (по умолчанию центр)
const controlCards: { img?: ImageMetadata; pos?: string; photoHint: string; title: string; text: string }[] = [
  {
    img: showcase('control-h2'),
    photoHint: 'Aqara H2 на стене крупным планом',
    title: 'Умный выключатель',
    text: 'Например, Aqara H2: сценарии и управление светом прямо на стене.',
  },
  {
    img: showcase('control-relay'),
    pos: '50% 35%',
    photoHint: 'Традиционный выключатель + реле в подрозетнике',
    title: 'Ваш любимый выключатель',
    text: 'Реле прячется в подрозетник — любой традиционный выключатель становится умным.',
  },
  {
    img: showcase('control-panel'),
    photoHint: 'Панель Aqara S1 Plus с включённым экраном',
    title: 'Настенная панель',
    text: 'Например, Aqara S1 Plus: свет, шторы и сценарии с изящного экрана на стене.',
  },
  {
    img: showcase('control-tablet'),
    pos: '50% 100%',
    photoHint: 'Планшет с вашим интерфейсом',
    title: 'Планшет с интерфейсом',
    text: 'Весь дом на одном экране. Интерфейс рисуем под вас — и под гостей.',
  },
];

const protocols = [
  { name: 'Zigbee', note: 'Тысячи датчиков, выключателей и ламп в собственной mesh-сети' },
  { name: 'Wi-Fi', note: 'Умные устройства в вашей существующей сети' },
  { name: 'Thread', note: 'Энергоэффективная mesh-сеть нового поколения' },
  { name: 'Matter', note: 'Полная поддержка нового стандарта. На вход и на выход' },
  { name: 'DALI', note: 'Профессиональное управление светом: диммирование без мерцания' },
  { name: 'Casambi', note: 'Беспроводное профессиональное управление светом' },
  { name: 'Bluetooth', note: 'Замки, датчики, аудиосистемы рядом с сервером' },
  { name: 'Проводные системы', note: 'Интегрируем существующие шинные и релейные инсталляции' },
];

---

<Layout>
  <!-- YourSpace intro -->
  <section class="home-page-main">
    <div class="layout">
      <div class="home-page-main__grid">
        <div class="home-page-main__content">
          <h1>YourSpace —
            <span class="title-sub">умный дом, который объединяет всё!</span>
          </h1>
          <p class="home-page-main__lead">
            Свет, климат, музыка и безопасность любых брендов — в одном
            приложении. Локально: надёжно и конфиденциально.
          </p>
          <ul class="hero-chips">
            <li>Работает без интернета</li>
            <li>Без штробления и сверления</li>
            <li>35+ готовых сценариев</li>
            <li>Алиса, Siri и Apple Home</li>
          </ul>
          <div class="hero-actions">
            <a class="button glancing" href="#demo">Потрогать живое демо</a>
            <button class="button-light popup-trigger">Обсудить проект</button>
          </div>
        </div>
        {demoCover ? (
          <a class="home-page-main__image home-page-main__image--demo" href="#demo" aria-label="К живому демо умного дома">
            <span class="home-page-main__badge">● Живое демо</span>
            <Image src={demoCover} alt="Интерфейс умного дома YourSpace — живое демо" />
          </a>
        ) : (
          <a class="home-page-main__image" href="#demo" aria-label="К живому демо умного дома">
            <Image src={SHFEATURES1} alt="Умный дом" />
          </a>
        )}
      </div>
    </div>
  </section>

  <div class="header-brands">
    <div class="header-brands__label">Все бренды в одном приложении у вас дома</div>
    <div class="brands-marquee">
      <div class="brands-marquee__track">
        {[0, 1].map((copy) => (
          <div class="brands-marquee__group" aria-hidden={copy === 1 ? 'true' : undefined}>
            {brands.map((brand) => {
              const logo = brandLogo(brand);
              return logo
                ? <Image src={logo} alt={brand.name} class="brands-marquee__logo" />
                : <span class="brands-marquee__badge">{brand.name}</span>;
            })}
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- live demo -->
  <section id="demo" class="section-blue home-page-demo">
    <div class="layout">
      <h2>Потрогайте умный дом прямо&nbsp;сейчас</h2>
      <div class="home-page-demo__embed reveal">
        <iframe
          src={DEMO_HA_URL}
          title="Живое демо умного дома YourSpace"
          loading="lazy"
          allow="fullscreen"
        ></iframe>
      </div>
      <a
        class="home-page-demo__frame reveal"
        href={DEMO_HA_URL}
        target="_blank"
        rel="noopener"
        aria-label="Открыть живое демо умного дома в новой вкладке"
      >
        <span class="home-page-demo__badge">● Живое демо</span>
        {demoCover
          ? <Image src={demoCover} alt="Интерфейс умного дома YourSpace" />
          : <span class="photo-placeholder photo-placeholder--wide">📷 Скрин дашборда HA (~1600×1000)</span>
        }
      </a>
    </div>
  </section>

  <!-- Protocols -->
  <section id="protocols" class="home-page-protocols section-blue">
    <div class="layout">
      <h2>Работаем со всеми протоколами</h2>
      <p class="home-page-protocols__subtitle">
        Умный свет по Zigbee, DALI и Casambi, весь Matter, беспроводные датчики
        и интеграция проводных систем — в одном доме.
      </p>
      <div class="home-page-protocols__grid">
        {protocols.map((protocol) => (
          <div class="card protocol-card reveal">
            <h3>{protocol.name}</h3>
            <p>{protocol.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Control options -->
  <section id="control" class="home-page-control">
    <div class="layout">
      <h2>Управление на любой вкус</h2>
      <div class="home-page-control__grid">
        {controlCards.map((card) => (
          <div class="card control-card reveal">
            {card.img
              ? <Image src={card.img} alt={card.title} loading="lazy" style={card.pos ? `object-position: ${card.pos}` : undefined} />
              : <span class="photo-placeholder">📷 {card.photoHint}</span>
            }
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Smart Home features -->
  <section id="features" class="home-page-features">
    <div class="layout">
      <SwiperComponent buttons autoplay={7000}>
        <SwiperSlide>
          <div class="home-page-features__slide">
            <h2>Возможности умного дома</h2>

            <h3 class="title-blue">Контроль климата</h3>
            <ul>
              <li>Тёплый пол по утрам</li>
              <li>Котел и батареи не жгут ресурсы, пока Вы на работе</li>
              <li>Комфортная среда, когда Вы дома</li>
            </ul>
          </div>
          <div class="home-page-features__slide-image">
            <Image src={SHFEATURES1} alt="smart home example"/>
          </div>
        </SwiperSlide>
        <SwiperSlide>
          <div class="home-page-features__slide-image home-page-features__slide-image--smaller">
            <Image src={SHFEATURES2} alt="smart home example"/>
          </div>
          <div class="home-page-features__slide">
            <h2>Возможности умного дома</h2>

            <h3 class="title-blue">Умные устройства</h3>
            <ul>
              <li>Шторы открываются по будильнику на телефоне</li>
              <li>Свет приглушается при включении фильма</li>
              <li>Робот-пылесос знает, когда Вы не дома</li>
            </ul>
          </div>
        </SwiperSlide>
        <SwiperSlide>
          <div class="home-page-features__slide">
            <h2>Возможности умного дома</h2>

            <h3 class="title-blue">Световые решения</h3>
            <ul>
              <li>Входите в освещённый дом</li>
              <li>Настройте тёплый свет для уютного вечера</li>
              <li>Выключайте всё одной кнопкой</li>
            </ul>
          </div>
          <div class="home-page-features__slide-image">
            <Image src={SHFEATURES3} alt="smart home example"/>
          </div>
        </SwiperSlide>
        <SwiperSlide>
          <div class="home-page-features__slide-image">
            <Image src={SHFEATURES4} alt="smart home example"/>
          </div>
          <div class="home-page-features__slide">
            <h2>Возможности умного дома</h2>

            <h3 class="title-blue">Безопасность</h3>
            <ul>
              <li>Кран перекроет воду или газ в случае утечки</li>
              <li>Датчик CO2 предупредит необходимость проветрить</li>
              <li>Датчик контакта сообщит о несанкционированном доступе</li>
            </ul>
          </div>
        </SwiperSlide>
      </SwiperComponent>

      <div class="home-page-features__actions">
        <a class="button glancing" href={withBase('/automations/')}>Прайс автоматизаций</a>
        <a class="button-light" href={withBase('/automations/#cases')}>Примеры проектов</a>
      </div>
    </div>
  </section>

  <!-- Work steps -->
  <section id="steps" class="home-page-work-steps section-blue">
    <div class="layout">
      <h2>Этапы работы</h2>
      <div class="home-page-work-steps__wrapper">
      <div class="home-page-work-steps__item">
        <div class="home-page-work-steps__pic">
          <Image src={STEP1} alt="первый этап работы" />
        </div>
        <div class="home-page-work-steps-divider home-page-work-steps-divider--first">
          <span>1</span>
        </div>
        <div class="home-page-work-steps__description">
          <h3>Обсуждаем пожелания</h3>
          <p>Мы предлагаем, а Вы выбираете! Каталог сценариев и многолетний опыт интеграций</p>
        </div>
      </div>

      <div class="home-page-work-steps__item">
        <div class="home-page-work-steps__pic">
          <Image src={STEP2} alt="второй этап работы" />
        </div>
        <div class="home-page-work-steps-divider">
          <span>2</span>
        </div>
        <div class="home-page-work-steps__description">
          <h3>Проводим замер</h3>
          <p>Осматриваем электрику, умные и традиционные устройства, обсуждаем реализацию</p>
        </div>
      </div>

      <div class="home-page-work-steps__item">
        <div class="home-page-work-steps__pic">
          <Image src={STEP3} alt="третий этап работы" />
        </div>
        <div class="home-page-work-steps-divider">
          <span>3</span>
        </div>
        <div class="home-page-work-steps__description">
          <h3>Собираем умный дом</h3>
          <p>Устанавливаем сервер, монтируем электрику, приклеиваем датчики</p>
        </div>
      </div>

      <div class="home-page-work-steps__item">
        <div class="home-page-work-steps__pic home-page-work-steps__pic--last">
          <Image src={STEP4} alt="четвертый этап работы" />
        </div>
        <div class="home-page-work-steps-divider home-page-work-steps-divider--last">
          <span>4</span>
        </div>
        <div class="home-page-work-steps__description home-page-work-steps__description--last">
          <h3>Программируем под Вас</h3>
          <p>Подстраиваем умный дом под Ваши привычки, все тщательно тестируем и оставляем инструкции</p>
        </div>
      </div>
      </div>
    </div>
  </section>

  <!-- voice assistant -->
  <section id="voice" class="home-page-voice section-blue">
    <div class="layout">
      <h2>голосовой помощник</h2>
      <h3 class="title-blue">Алиса научится управлять всем — даже тем, что Яндекс не поддерживает</h3>
      <div class="simple-grid">
        <div class="home-page-voice__info">
          <p>
            Устройства попадают в Алису через ваш сервер, поэтому для неё Casambi-светильник,
            проводной термостат или фанкойл — обычные умные устройства.
            Управляйте голосом, из приложения Яндекса и даже из CarPlay.
          </p>
          <ul>
            <li>Светильники Casambi и DALI</li>
            <li>Редкие и уникальные Zigbee-устройства</li>
            <li>Проводные системы</li>
            <li>Apple Home и Siri — так же, параллельно</li>
          </ul>
        </div>
        <div class="home-page-voice__diagram reveal" role="img" aria-label="Схема: устройства подключаются к серверу умного дома, а сервер — к Алисе, приложению Яндекса, CarPlay и Apple Home">
          <div class="voice-diagram__col">
            <span class="voice-diagram__chip">Светильник Casambi</span>
            <span class="voice-diagram__chip">Светильник DALI</span>
            <span class="voice-diagram__chip">Zigbee-устройство</span>
            <span class="voice-diagram__chip">Проводной термостат</span>
            <span class="voice-diagram__chip">Фанкойл</span>
          </div>
          <div class="voice-diagram__link" aria-hidden="true"></div>
          <div class="voice-diagram__hub">Сервер умного дома</div>
          <div class="voice-diagram__link" aria-hidden="true"></div>
          <div class="voice-diagram__col">
            <span class="voice-diagram__chip voice-diagram__chip--accent">Алиса</span>
            <span class="voice-diagram__chip voice-diagram__chip--accent">Приложение Яндекса</span>
            <span class="voice-diagram__chip voice-diagram__chip--accent">CarPlay</span>
            <span class="voice-diagram__chip voice-diagram__chip--accent">Apple Home</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="layout plan">
    <div class="plan__banner reveal">
      <h2>Работаем от одного устройства</h2>
      <p>Расскажите, что хотите автоматизировать, — предложим решение и посчитаем стоимость</p>
      <button class="button glancing popup-trigger">Давайте обсудим ваш проект</button>
    </div>
  </section>

  <!-- CAT -->
  <CatOnVacuum/>
  <Popup/>

</Layout>

<!--
  Логика показа попапа консультации:

  УСЛОВИЯ ПОКАЗА:
  1. Пользователь проскроллил ниже первого экрана (на высоту viewport)
  2. Пользователь не скроллит 2+ секунд
  3. Пользователь не кликает 3+ секунд
  4. Вкладка активна (не скрыта)
  5. Прошло 8 секунд с момента последней активности

  ТАЙМЕРЫ:
  - 2 сек - пауза в скролле (если пользователь перестал скроллить)
  - 3 сек - пауза в кликах (если пользователь перестал кликать)
  - 8 сек - основной таймер показа попапа

  ОТМЕНА ТАЙМЕРОВ:
  - При любом скролле
  - При любом клике
  - При скрытии вкладки
  - При изменении размера окна
  - После показа попапа (один раз за сессию)

  ЦЕЛЬ: Показывать попап только когда пользователь активно читает контент,
  но не мешать взаимодействию с интерфейсом.
-->
<script>
document.addEventListener('DOMContentLoaded', () => {
  let timerId: number | null = null;
  let hasTriggered = false;
  let isScrolling = false;
  let scrollTimeout: number | null = null;
  let isClicking = false;
  let clickTimeout: number | null = null;

  const startTimer = () => {
    if (hasTriggered || timerId || isClicking) return;

    // Проверяем, что пользователь проскроллил хотя бы на высоту экрана
    const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    const viewportHeight = window.innerHeight || document.documentElement.clientHeight;

    if (scrollTop < viewportHeight) {
      return; // Не показываем попап на первом экране
    }

    timerId = window.setTimeout(triggerPopup, 8000); // 8 секунд
  };

  const cancelTimer = () => {
    if (timerId) {
      clearTimeout(timerId);
      timerId = null;
    }
  };

  const triggerPopup = () => {
    if (hasTriggered) return;
    hasTriggered = true;

    window.dispatchEvent(new CustomEvent('open-contact-popup'));

    cancelTimer();
    window.removeEventListener('scroll', onScroll);
    window.removeEventListener('resize', onResize);
    window.removeEventListener('visibilitychange', onVisibilityChange);
    document.removeEventListener('click', onClick);
  };

  const onScroll = () => {
    isScrolling = true;

    // Отменяем предыдущий таймер скролла
    if (scrollTimeout) {
      clearTimeout(scrollTimeout);
    }

    // Запускаем новый таймер - если через 2 секунды скролл остановится
    scrollTimeout = window.setTimeout(() => {
      isScrolling = false;
      // Если вкладка активна и пользователь не скроллит и не кликает - запускаем основной таймер
      if (!document.hidden && !isClicking) {
        startTimer();
      }
    }, 2000);
  };

  const onClick = () => {
    isClicking = true;

    // Отменяем основной таймер при клике
    cancelTimer();

    // Отменяем предыдущий таймер клика
    if (clickTimeout) {
      clearTimeout(clickTimeout);
    }

    // Запускаем новый таймер - если через 3 секунды не будет кликов
    clickTimeout = window.setTimeout(() => {
      isClicking = false;
      // Если вкладка активна и пользователь не скроллит - запускаем основной таймер
      if (!document.hidden && !isScrolling) {
        startTimer();
      }
    }, 3000);
  };

  const onResize = () => {
    // При изменении размера окна отменяем таймеры
    cancelTimer();
    if (scrollTimeout) {
      clearTimeout(scrollTimeout);
      scrollTimeout = null;
    }
    if (clickTimeout) {
      clearTimeout(clickTimeout);
      clickTimeout = null;
    }
  };

  const onVisibilityChange = () => {
    if (document.hidden) {
      // Если вкладка скрыта - отменяем все таймеры
      cancelTimer();
      if (scrollTimeout) {
        clearTimeout(scrollTimeout);
        scrollTimeout = null;
      }
      if (clickTimeout) {
        clearTimeout(clickTimeout);
        clickTimeout = null;
      }
    } else {
      // Если вкладка стала активной и пользователь не скроллит и не кликает - запускаем таймер
      if (!isScrolling && !isClicking) {
        startTimer();
      }
    }
  };

  // Запускаем отслеживание скролла и кликов
  window.addEventListener('scroll', onScroll);
  window.addEventListener('resize', onResize);
  window.addEventListener('visibilitychange', onVisibilityChange);
  document.addEventListener('click', onClick);
});

</script>



<style is:global>
  .home-page-features .swiper-wrapper {
    margin-bottom: calc(var(--space) * 0.5);
  }

  .home-page-features .layout {
    padding-top: 0;
  }
</style>


<style>

  h1 {
    position: relative;
    display: flex;
    flex-direction: column;
    margin-bottom: var(--space);
    z-index: 2;
  }

  h1 .title-blue {
    font-weight: 700;
    text-transform: uppercase;
  }

  h2 {
    text-transform: uppercase;
  }

  .swiper-slide {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .simple-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space);
  }

  /* photo placeholders (пока нет реальных фото) */

  .photo-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 4 / 3;
    padding: var(--space);
    text-align: center;
    font-size: calc(var(--base-font-size) * 0.85);
